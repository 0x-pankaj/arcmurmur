# ===========================================
# ArcMurmur — environment configuration
# Copy to .env (root) and fill in your values.
# All packages read from the root .env automatically.
# ===========================================

# --- Arc Testnet (Circle L1) ---
# Public RPC; your custom Canteen swarm endpoint is fine too.
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
ARC_EXPLORER_URL=https://testnet.arcscan.app
NEXT_PUBLIC_ARC_EXPLORER_URL=https://testnet.arcscan.app

# Arc Testnet native USDC (ERC-20 interface, 6 decimals).
# Reference: docs.arc.io/arc/references/contract-addresses
NEXT_PUBLIC_ARC_USDC=0x3600000000000000000000000000000000000000

# Deployed StigmergySignal + SwarmVault + MarketProposals contracts on Arc testnet
# (run `pnpm contracts:deploy` to deploy + auto-fill these)
NEXT_PUBLIC_STIGMERGY_CONTRACT=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_VAULT_CONTRACT=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_PROPOSALS_CONTRACT=0x0000000000000000000000000000000000000000

# ERC-8004 registries are pre-deployed by Arc — no action needed
# IdentityRegistry:   0x8004A818BFB912233c491871b3d84c89A494BD9e
# ReputationRegistry: 0x8004B663056A597Dffe9eCcC1965A193B7388713
# ValidationRegistry: 0x8004Cb1BF31DAf7788923b405b754f57acEB4272
# Register the swarm:  pnpm register:agents

# Arc Testnet CCTP v2 (domain 26)
ARC_CCTP_TOKEN_MESSENGER=0x8FE6B999Dc680CcFDD5Bf7EB0974218be2542DAA
ARC_CCTP_MESSAGE_TRANSMITTER=0xE737e5cEBEEBa77EFE34D4aa090756590b1CE275
ARC_CCTP_TOKEN_MINTER=0xb43db544E2c27092c107639Ad201b3dEfAbcF192
ARC_CCTP_DOMAIN=26

# --- Polygon mainnet (Polymarket lives here) ---
POLYGON_RPC_URL=https://polygon-rpc.com
POLYGON_CHAIN_ID=137
NEXT_PUBLIC_POLYGON_USDC=0x3c499c542cEF5E3811e1192ce70d8cC03d5c3359
POLYGON_CCTP_DOMAIN=7

# --- Polygon Amoy testnet (safer demo target for CCTP) ---
POLYGON_AMOY_RPC_URL=https://rpc-amoy.polygon.technology
POLYGON_AMOY_CHAIN_ID=80002
POLYGON_AMOY_USDC=0x41E94Eb019C0762f9Bfcf9Fb1E58725BfB0e7582
# Set BRIDGE_DEST=amoy to keep the demo fully testnet (recommended).
BRIDGE_DEST=amoy

# --- Polymarket (V2 CLOB) ---
# Create your OWN builder code + API creds at
# https://polymarket.com/settings?tab=builder — never reuse someone else's.
# Only needed for live mainnet mode (DEMO_MODE=false). Gamma host (read-only
# market data) works without any of these.
POLYMARKET_BUILDER_ADDRESS=0x0000000000000000000000000000000000000000
POLYMARKET_BUILDER_CODE=
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_CLOB_HOST=https://clob.polymarket.com
POLYMARKET_GAMMA_HOST=https://gamma-api.polymarket.com

# --- Agent wallets (TEST ONLY — never use mainnet wallets) ---
# Run `pnpm keys:generate` once to populate these and fund them
# from https://faucet.circle.com (select Arc Testnet).
DEPLOYER_PRIVATE_KEY=
AGENT_CRYPTO_PRIVATE_KEY=
AGENT_POLITICS_PRIVATE_KEY=
AGENT_MACRO_PRIVATE_KEY=
AGENT_SPORTS_PRIVATE_KEY=

# --- LLM (via OpenRouter, routed through Vercel AI SDK) ---
OPENROUTER_API_KEY=sk-or-v1-replace-me
OPENROUTER_MODEL=deepseek/deepseek-v4-pro
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Set to true to expose chain-of-thought in the dashboard.
OPENROUTER_REASONING=true

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
SWARM_TICK_INTERVAL_MS=60000
DEMO_MODE=true

# --- LLM budget controls (kill OpenRouter cost) ---
# Total LLM calls per tick = markets × (1 + wildcard?) + propose?
# Defaults give ~3 LLM calls per tick (was ~10).
LLM_MAX_MARKETS_PER_TICK=3
LLM_INCLUDE_WILDCARD=false
LLM_SKIP_OUT_OF_DOMAIN=true
LLM_CACHE_TTL_MS=300000
LLM_CACHE_PRICE_DELTA=0.02
LLM_MIN_CONVICTION_PROPOSAL=0.7
LLM_MAX_PROPOSALS_PER_TICK=1

# --- Funding ---
# Per-agent USDC top-up when running `pnpm fund:agents` (default 100).
FUND_PER_AGENT_USDC=100

# --- New-user welcome drop (Claim test USDC button) ---
# Amount dropped to a user's connected wallet on first click (default 10).
WELCOME_DROP_USDC=10
# Disable the welcome drop entirely on the public Vercel deployment if you
# want to avoid deployer drain. Set to false to disable.
WELCOME_DROP_ENABLED=true
