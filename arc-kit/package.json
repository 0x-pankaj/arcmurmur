    "./abi": "./src/abi.ts",
    "./x402-client": "./src/x402-client.ts",
    "./x402-server": "./src/x402-server.ts",
    "./session-keys": "./src/session-keys.ts",
    "./cctp": "./src/cctp.ts",
    "./stigmergy": "./src/stigmergy.ts",
    "./erc8004": "./src/erc8004.ts"
  },
  "scripts": {
    "check-types": "tsc --noEmit"
