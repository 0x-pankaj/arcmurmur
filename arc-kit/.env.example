# arc-kit — environment. Copy to .env and fill in. All values have sane
# Arc Testnet defaults, so most are optional.

# --- Arc Testnet (Circle's stablecoin-native L1) ---
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
ARC_EXPLORER_URL=https://testnet.arcscan.app

# Native USDC (ERC-20 interface, 6 decimals) — same on every Arc deploy.
NEXT_PUBLIC_ARC_USDC=0x3600000000000000000000000000000000000000

# CCTP v2 on Arc (domain 26) — defaults baked into chain.ts, override if needed.
ARC_CCTP_TOKEN_MESSENGER=0x8FE6B999Dc680CcFDD5Bf7EB0974218be2542DAA
ARC_CCTP_DOMAIN=26

# Your deployed StigmergySignal contract (run your own deploy of contracts/).
STIGMERGY_CONTRACT=

# A funded Arc wallet for server-side / agent txs (TEST KEY ONLY).
# Fund it with USDC from https://faucet.circle.com (select Arc Testnet).
PRIVATE_KEY=

# x402 server: who receives unlock payments.
INTEL_RECEIVER=
